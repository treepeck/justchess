{{ define "layout" }}

<div class="game-layout flex-container">
  <div class="chat-layout game-container">
    <header class="game-container-header">Chat</header>
    <div id="chat" class="scrollable-container"></div>

    <div class="chat-input">
      <input
        id="chatInput"
        type="text"
        placeholder="Enter your message"
        autocomplete="off"
      />
      <div id="chatSend"></div>
    </div>

    <div class="game-controls">
      <button id="offerDrawBtn">Offer draw</button>
      <button id="resignBtn">Resign</button>
	</div>
  </div>

  {{ block "board" . }}{{ end }}
</div>

<div id="ping">Ping: ? ms</div>

<div id="endgameDialog" class="dialog flex-container">
  <div class="dialog-layout">
    <p class="dialog-header">Game over</p>

    <p id="endgameDialogResult">{{ formatResult .Data.Result }}</p>
    <p id="endgameDialogTermination">{{ formatTermination .Data.Termination }}</p>

    <button id="endgameDialogClose" class="dialog-close">OK</button>
  </div>
</div>

<div id="offerDrawDialog" class="dialog flex-container">
  <div class="dialog-layout">
    <p class="dialog-header">Offer draw</p>

    <p>Do you really want to offer a draw?</p>

    <div class="dialog-buttons">
      <button id="offerDrawDialogClose">Close</button>
      <button id="offerDrawDialogAccept">Accept</button>
    </div>
  </div>
</div>

<div id="acceptDrawDialog" class="dialog flex-container">
  <div class="dialog-layout">
    <p class="dialog-header">Draw offer from opponent</p>

    <p>Do you accept your opponent's offer of a draw?</p>

    <div class="dialog-buttons">
      <button id="acceptDrawDialogClose">Decline</button>
      <button id="acceptDrawDialogAccept">Accept</button>
    </div>
  </div>
</div>

<div id="resignDialog" class="dialog flex-container">
  <div class="dialog-layout">
    <p class="dialog-header">Resign</p>

    <p>Do you really want to end the game by resigning?</p>

    <div class="dialog-buttons">
      <button id="resignDialogClose">Close</button>
      <button id="resignDialogAccept">Accept</button>
    </div>
  </div>
</div>
<div id="activeGameGuard"></div>

{{ end }}