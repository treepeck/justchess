{{ define "title" }}Reset Password{{ end }}
{{ define "layout" }}
<h1><b>Reset password</b></h1>

<form id="resetPasswordForm" class="form flex">
  <div class="form-section">
    <p class="form-input-label">Email address</p>
    <input
      type="text"
      name="email"
      autocomplete="off"
      placeholder="magnus@carlsen.com"
    />
    <div class="form-error" id="formEmailError"></div>
  </div>

  <div class="form-section">
    <p class="form-input-label">New password</p>
    <div class="form-password">
      <input
        id="formPasswordInput"
        type="password"
        name="password"
        autocomplete="off"
        placeholder="*************"
      />
      <div id="formPasswordToggle"></div>
    </div>

    <div class="form-error" id="formPasswordError"></div>
  </div>

  <div id="serverResponse"></div>
  <button id="formSubmitButton">Confirm</button>
</form>
{{ end }}