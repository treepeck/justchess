{{ define "layout" }}
<h1 class="page-header">Create your account</h1>

<form id="authForm" class="form flex">
  <div class="form-section">
    <p class="form-input-label">Username</p>
    <input
      type="text"
      name="name"
      autocomplete="off"
      placeholder="MagnusCarlsen"
    />
    <div class="form-error" id="formNameError"></div>
  </div>

  <div class="form-section">
    <p class="help-text form-input-label" id="helpDialogActivator">
      Email address
    </p>
    <input
      type="text"
      name="email"
      autocomplete="off"
      placeholder="magnus@carlsen.com"
    />
    <div class="form-error" id="formEmailError"></div>
  </div>

  <div class="form-section">
    <p class="form-input-label">Password</p>
    <div class="form-password">
      <input
        id="formPasswordInput"
        type="password"
        name="password"
        autocomplete="off"
        placeholder="*************"
      />
      <div id="formPasswordToggle"></div>
    </div>

    <div class="form-error" id="formPasswordError"></div>
  </div>

  <div id="serverResponse"></div>
  <button id="formSubmitButton" class="button">Sign up</button>

  <small>Already have an account? <a href="/signin">Sign in</a></small>
</form>

<div id="helpDialog" class="dialog flex">
<div class="dialog-layout flex">
  <div class="dialog-header">Why do I need to enter my email address?</div>

  <p>To securely reset your password if you forget it.</p>
  <p>Your email will never be shared or used for any other purpose.</p>

  <button id="helpDialogClose" class="dialog-close button">OK</button>
</div>
</div>

<div id="confirmDialog" class="dialog flex">
  <div class="dialog-layout flex">
    <div class="dialog-header">Please note</div>

    <p>Accounts with offensive or inappropriate names will be <b>blocked</b>.</p>

    <div class="dialog-buttons">
      <button id="confirmDialogClose" class="button">Cancel</button>
      <button id="confirmDialogConfirm" class="button">Confirm</button>
    </div>
  </div>
</div>
{{ end }}