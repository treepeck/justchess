{{ define "layout" }}
<div class="game-layout flex" data-terminated="{{ if ne .Data.Termination 0 }}true{{ else }}false{{ end }}">
  {{ if eq .Data.Termination 0 }}
    <div class="chat-layout flex">
      <h2>Chat</h2>
      <div id="chat" class="scrollable"></div>
      <div class="chat-input">
        <input
          id="chatInput"
          type="text"
          placeholder="Enter your message"
          autocomplete="off"
        />
        <div id="chatSend"></div>
      </div>

      <div class="game-controls">
        <button id="offerDrawBtn" class="button">Offer draw</button>
        <button id="resignBtn" class="button">Resign</button>
      </div>
    </div>
  {{ end }}

  <div class="board-layout {{ if eq .Data.Black.Name .Player.Name}}flipped{{ end }}">
    <div class="board-black-miniprofile">
      <a href="/player/{{ .Data.Black.Id }}" class="board-miniprofile a">{{ .Data.Black.Name }}</a>
      <div class="board-miniprofile-rating">({{ round .Data.Black.Rating }} mmr)</div>
      <div id="blackClock" class="board-miniprofile-clock">{{ .Data.Control }}</div>
    </div>

    <div id="board"></div>

    <div class="board-white-miniprofile">
      <a href="/player/{{ .Data.White.Id }}" class="board-miniprofile a">{{ .Data.White.Name }}</a>
      <div class="board-miniprofile-rating">({{ round .Data.White.Rating }} mmr)</div>
      <div id="whiteClock" class="board-miniprofile-clock">{{ .Data.Control }}</div>
    </div>
  </div>

  <div class="move-table-layout flex">
    <h2>Moves</h2>

    <div id="moves" class="scrollable">
      {{ range $i, $v := .Data.Moves }}
        {{ if mod $i 2 | eq 0 }}
          <div id="row{{ div $i 2 }}" class="move-table-row">
            <div class="move-table-ply">{{ div $i 2 | add 1 }}.</div>
            <div id="{{ $i }}" class="move-table-row-san" data-fen="{{ $v.Fen }}" data-timediff="{{ index $.Data.TimeDiffs $i }}">
              {{ $v.San }}
            </div>
            {{ if len $.Data.Moves | sub 1 | eq $i }}</div>{{ end }}
        {{ else }}
            <div id="{{ $i }}" class="move-table-row-san" data-fen="{{ $v.Fen }}" data-timediff="{{ index $.Data.TimeDiffs $i }}">
              {{ $v.San }}
            </div>
          </div>
        {{ end }}
      {{ end }}
    </div>

    <div class="move-table-board-controls">
      <button id="nullMoveBtn"></button>
      <button id="prevMoveBtn"></button>
      <button id="nextMoveBtn"></button>
      <button id="lastMoveBtn"></button>
      <button id="flipBoardBtn"></button>
    </div>
  </div>
</div>

{{ if eq .Data.Termination 0 }}
  <div id="ping">Latency: ? ms</div>

  <div id="offerDrawDialog" class="dialog flex">
    <div class="dialog-layout flex">
      <div class="dialog-header">Offer draw</div>

      <p>Do you really want to offer a draw?</p>

      <div class="dialog-buttons">
        <button id="offerDrawDialogClose" class="button">Close</button>
        <button id="offerDrawDialogAccept" class="button">Accept</button>
      </div>
    </div>
  </div>

  <div id="acceptDrawDialog" class="dialog flex">
    <div class="dialog-layout flex">
      <div class="dialog-header">Draw offer from opponent</div>

      <p>Do you accept your opponent's offer of a draw?</p>

      <div class="dialog-buttons">
        <button id="acceptDrawDialogClose" class="button">Decline</button>
        <button id="acceptDrawDialogAccept" class="button">Accept</button>
      </div>
    </div>
  </div>

  <div id="resignDialog" class="dialog flex">
    <div class="dialog-layout flex">
      <div class="dialog-header">Resign</div>

      <p>Do you really want to resign?</p>

      <div class="dialog-buttons">
        <button id="resignDialogClose" class="button">Close</button>
        <button id="resignDialogAccept" class="button">Accept</button>
      </div>
    </div>
  </div>
{{ end }}

<div id="endgameDialog" class="dialog flex">
  <div class="dialog-layout flex">
    <div class="dialog-header">Game over</div>

    <p id="endgameDialogResult">{{ .Data.Result }}</p>
    <p id="endgameDialogTermination">{{ .Data.Termination }}</p>

    <button id="endgameDialogClose" class="dialog-close button">OK</button>
  </div>
</div>

{{ end }}